# ============================================
# OKR Backend - Environment Configuration
# ============================================
# Copia este archivo a .env y configura los valores
# cp .env.example .env
# ============================================

# Database Configuration
# ----------------------
POSTGRES_DB=change
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change

# JWT Configuration
# ----------------
# IMPORTANTE: Genera una clave segura para producción
# Ejemplo: openssl rand -base64 32
JWT_SECRET=change
# CORS Configuration
# ------------------
# Orígenes permitidos separados por coma
# Ejemplo: http://localhost:3000,https://midominio.com
CORS_ALLOWED_ORIGINS=change

# Admin User
# ---------
ADMIN_EMAIL=change
ADMIN_PASSWORD=change